# EditorConfig helps maintain consistent code styles across editors and teams

root = true

# ==================== GLOBAL ====================

[*]
#charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ==================== PYTHON (BACKEND) ====================

[*.py]
max_line_length = 100
indent_size = 4
trim_trailing_whitespace = true

[backend/**/*.py]
indent_size = 4
end_of_line = lf

[backend/core/*.py]
indent_size = 4
trim_trailing_whitespace = true

[backend/api/*.py]
indent_size = 4
trim_trailing_whitespace = true

[backend/tasks/*.py]
indent_size = 4
trim_trailing_whitespace = true

# ==================== TYPESCRIPT/TSX (FRONTEND) ====================

[*.ts]
indent_size = 4
max_line_length = 120
trim_trailing_whitespace = true

[*.tsx]
indent_size = 4
max_line_length = 120
trim_trailing_whitespace = true

[frontend/**/*.ts]
indent_size = 4
trim_trailing_whitespace = true

[frontend/**/*.tsx]
indent_size = 4
trim_trailing_whitespace = true

# ==================== JAVASCRIPT ====================

[*.js]
indent_size = 4
max_line_length = 120
trim_trailing_whitespace = true

[*.mjs]
indent_size = 4
max_line_length = 120
trim_trailing_whitespace = true

# ==================== JSON/JSON5/YAML ====================

[package.json]
indent_size = 2
max_line_length = 120

[*.json]
indent_size = 2
max_line_length = 120

[*.yml]
indent_size = 2
max_line_length = 120

[*.yaml]
indent_size = 2
max_line_length = 120

[*.sql]
indent_size = 2
trim_trailing_whitespace = true

# ==================== CSS/SCSS/TAILWIND ====================

[*.css]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = true

[*.scss]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = true
end_of_line = lf

# ==================== HTML ====================

[*.html]
indent_size = 2
trim_trailing_whitespace = true
end_of_line = lf

# ==================== CONFIG FILES ====================

[.prettierrc]
indent_size = 2

[.eslintrc*]
indent_size = 2

[.gitignore]
indent_size = 2

[.env*]
indent_size = 2
trim_trailing_whitespace = true