# ============================================
# x-translator-mvp — Backend Environment Variables
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================

# ============================================
# Application
# ============================================
# Environnement : development, staging, production
APP_ENV=development

# Clé secrète pour signer les tokens JWT (générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))")
APP_SECRET_KEY=change-me

# Origines autorisées pour CORS (séparées par des virgules)
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Base de données (PostgreSQL)
# ============================================
# Format : postgresql://user:password@host:port/database
DATABASE_URL=postgresql://translator:translator@localhost:5433/x_translator

# ============================================
# Groq API — Transcription Whisper
# ============================================
# Obtenir : https://console.groq.com/keys
# Modèle : whisper-large-v3-turbo
GROQ_API_KEY=gsk_your_groq_api_key_here

# ============================================
# OpenRouter API — Traduction LLM
# ============================================
# Obtenir : https://openrouter.ai/
# Modèle : deepseek/deepseek-chat-v3-0324
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ============================================
# Supabase — Stockage vidéos & Auth
# ============================================
# URL de votre projet Supabase
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (pour upload backend) — DIFFÉRENT de l'anon key
# Obtenir dans : Settings > API
SUPABASE_SERVICE_KEY=eyJyour_service_role_key_here

# Nom du bucket pour les vidéos traduites
SUPABASE_BUCKET=translated-videos

# ============================================
# Redis — Celery Broker
# ============================================
# Format : redis://host:port/db
REDIS_URL=redis://localhost:6379/0

# ============================================
# Stripe — Paiement (optionnel pour MVP)
# ============================================
# Obtenir : https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Clé publishable pour le frontend
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Secret pour les webhooks Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Prix Stripe (remplacer par vos prix réels)
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id

# Prix pour 10 crédits de traduction
STRIPE_PRICE_CREDITS_10=price_your_10_credits_price_id

# ============================================
# Watermark
# ============================================
# Texte du watermark sur la vidéo
WATERMARK_TEXT=spottedyou.org

# ============================================
# Frontend URL (pour callbacks)
# ============================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.railway.app