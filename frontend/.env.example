# ============================================
# x-translator-mvp — Frontend Environment Variables
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================

# ============================================
# API Backend
# ============================================
# URL de l'API backend (Railway ou localhost)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Remplacer par l'URL de production : https://api.yourdomain.railway.app

# ============================================
# Supabase — Auth & Storage
# ============================================
# URL de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon Key (publique) — à obtenir dans : Settings > API
# DIFFÉRENTE de la Service Role Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJyour_anon_key_here

# ============================================
# Stripe — Paiement (optionnel pour MVP)
# ============================================
# Clé publishable pour Stripe Elements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ============================================
# Features (optionnel)
# ============================================
# Activer/désactiver certaines fonctionnalités
NEXT_PUBLIC_ENABLE_BILLING=true
NEXT_PUBLIC_ENABLE_DOWNLOAD=true